# Pricoin pool configuration. Copy to config.toml; never commit secrets.

[pricoind]
# JSON-RPC connection to the pricoind that supplies block templates and
# accepts submitblock + walletsendct_multi.
rpc_host     = "127.0.0.1"
rpc_port     = 8332
datadir      = "~/.pricoin"   # used to read .cookie if rpc_user is unset
rpc_user     = ""
rpc_password = ""
wallet       = "pool"         # the wallet that owns the coinbase + payout funds

[pool]
# Pool-wide identity + economics.
coinbase_address     = ""           # transparent P2WPKH; coinbase mines here
fee_percent          = 1.0          # taken off the top of every block reward
extra_nonce_size     = 4            # bytes of nonce2 the pool reserves
share_target_seconds = 10.0         # vardiff aims at ~one share per worker per

[pplns]
# Pay Per Last N Shares window. n_shares is the number of accepted shares
# (across ALL workers) considered for a single block's split.
n_shares       = 3000
prune_after_h  = 24                 # drop share rows older than N hours

[vardiff]
min_difficulty   = 1
max_difficulty   = 4294967296       # 2^32, fine for any current GPU/CPU
retarget_after   = 16               # check every N submits
adjust_high      = 1.4              # > target * adjust_high  → halve diff
adjust_low       = 0.7              # < target * adjust_low   → double diff
initial_diff     = 1024             # diff each new connection starts at

[stratum]
listen_host       = "0.0.0.0"
listen_port       = 3333
refresh_interval_s = 5              # how often to re-poll getblocktemplate

[payouts]
# Run every payout_interval seconds; pay any user whose balance is at least
# their per-user min (defaults to default_min_payout) up to batch_size per
# walletsendct_multi tx.
default_min_payout = 0.1            # PRIC
batch_size         = 50             # recipients per tx
fee_per_payout     = 0.0001         # PRIC; flat per-tx; subtracted before split
payout_interval_s  = 600            # 10 minutes

[rxshare]
# Hardware-mode RandomX dataset for share verification. ~2.08 GB resident
# per dataset; we keep two for hot epoch rotation (current + pending).
init_threads = 8                    # parallelism for randomx_init_dataset
flags        = "auto"               # "auto" | comma list of HARD_AES,LARGE_PAGES,JIT,SECURE,FULL_MEM
                                    # "auto" picks via randomx_get_flags() + adds FULL_MEM

[web]
listen_host = "127.0.0.1"
listen_port = 5099
